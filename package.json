{
  "name": "bib-indexer",
  "displayName": "Bib Indexer",
  "description": "Bibliography manager for researchers with separate bib files per paper",
  "version": "0.1.0",
  "publisher": "DominikPeters",
  "license": "MIT",
  "homepage": "https://github.com/DominikPeters/bib-indexer",
  "repository": {
    "type": "git",
    "url": "https://github.com/DominikPeters/bib-indexer.git"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "bibtex",
    "bibliography",
    "latex",
    "research",
    "citation",
    "references"
  ],
  "activationEvents": [
    "onLanguage:bibtex",
    "workspaceContains:**/*.bib"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bibIndexer.addFolder",
        "title": "Bib Indexer: Add Folder to Index"
      },
      {
        "command": "bibIndexer.removeFolder",
        "title": "Bib Indexer: Remove Folder from Index"
      },
      {
        "command": "bibIndexer.reindex",
        "title": "Bib Indexer: Reindex All Files"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bibIndexer",
          "title": "Bib Indexer",
          "icon": "$(references)",
          "tooltip": "Bib Indexer"
        }
      ]
    },
    "views": {
      "bibIndexer": [
        {
          "id": "bibIndexer.main",
          "type": "webview",
          "name": "Bibliography"
        }
      ]
    },
    "configuration": {
      "title": "Bib Indexer",
      "properties": {
        "bibIndexer.indexedFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Folders to scan recursively for .bib files"
        },
        "bibIndexer.similarityThreshold": {
          "type": "number",
          "default": 0.85,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum similarity score (0-1) for matching entries"
        },
        "bibIndexer.ignoredFields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "keywords",
            "abstract",
            "month",
            "date-added",
            "date-modified",
            "bdsk-file-*"
          ],
          "description": "BibTeX fields to ignore (supports wildcards like 'bdsk-file-*')"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.3.9"
  },
  "dependencies": {
    "@retorquere/bibtex-parser": "^7.0.0",
    "flexsearch": "^0.7.43"
  }
}
